---
const commands = [
  { cmd: 'about', label: 'about' },
  { cmd: 'projects', label: 'projects' },
  { cmd: 'skills', label: 'skills' },
  { cmd: 'contact', label: 'contact' },
];
---

<nav class="mb-8">
  <div class="mb-2">
    <span class="terminal-prompt">visitor@portfolio</span>
    <span style="color: var(--terminal-text-dim);">:</span>
    <span style="color: var(--terminal-blue);">~</span>
    <span style="color: var(--terminal-text-dim);">$</span>
    <span class="terminal-command"> help</span>
  </div>
  
  <div class="command-block">
    <div style="color: var(--terminal-comment); margin-bottom: 12px;">
      Available commands:
    </div>
    
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">
      {commands.map((command) => (
        <a
          href={`#${command.cmd}`}
          class="flex items-center gap-2 px-3 py-2 hover:opacity-80 transition-opacity"
          style="background: var(--terminal-bg-secondary); border: 1px solid var(--terminal-border);"
        >
          <span style="color: var(--terminal-green);">→</span>
          <span style="color: var(--terminal-cyan);">./{command.label}</span>
        </a>
      ))}
    </div>
    
    <div class="flex items-center gap-4 pt-2" style="border-top: 1px dashed var(--terminal-border);">
      <button 
        id="theme-toggle"
        class="flex items-center gap-2 hover:opacity-80 transition-opacity"
        style="color: var(--terminal-yellow);"
      >
        <span>[</span>
        <span>theme: <span id="current-theme">dark</span></span>
        <span>]</span>
      </button>
      <span style="color: var(--terminal-comment); font-size: 12px;">
        - Toggle light/dark mode
      </span>
    </div>
  </div>
</nav>

<script>
  const themeToggle = document.getElementById('theme-toggle');
  const currentTheme = document.getElementById('current-theme');
  
  function updateThemeLabel() {
    const isDark = document.documentElement.classList.contains('dark');
    if (currentTheme) {
      currentTheme.textContent = isDark ? 'dark' : 'light';
    }
  }
  
  updateThemeLabel();
  
  themeToggle?.addEventListener('click', () => {
    document.documentElement.classList.toggle('dark');
    const isDark = document.documentElement.classList.contains('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    updateThemeLabel();
  });
</script>
